---
import "../styles/global.css";
import Icono from "../components/icono.jsx";
import Loading from "../components/cargando.jsx";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar Contraseña - Kiora</title>
    <Icono />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="m-0 font-[Inter] bg-[#fafafc] text-[#334155] flex flex-col items-center justify-center min-h-screen relative overflow-x-hidden"
  >
    <!-- Abstract Background Detail -->
    <div
      class="absolute -top-50 -right-25 w-150 h-150 rounded-full bg-[radial-gradient(circle,rgba(237,27,36,0.06)_0%,rgba(250,250,252,0)_70%)] -z-10 pointer-events-none"
    >
    </div>

    <!-- App Logo -->
    <img
      src="/img/logo-kiora-vectorizado.svg"
      alt="Kiora Logo"
      class="w-48 h-auto mt-4 mb-6 relative z-10 object-contain"
    />

    <p
      class="text-[0.95rem] text-[#64748b] m-0 mb-8 font-medium text-center max-w-md px-4"
    >
      Ingresa tu correo electrónico asociado a tu cuenta y te enviaremos
      instrucciones para restablecer tu contraseña.
    </p>

    <!-- Card -->
    <form
      id="recoverForm"
      class="bg-white w-full max-w-105 p-8 rounded-xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.04)]"
    >
      <!-- Correo electrónico -->
      <div class="mb-5">
        <label
          for="email"
          class="block font-semibold text-[0.85rem] text-[#374151] mb-2"
          >Correo electrónico</label
        >
        <div
          class="relative flex items-center border border-gray-300 rounded-lg bg-white overflow-hidden transition-all duration-200 focus-within:border-[#9ca3af] focus-within:ring-[3px] focus-within:ring-gray-400/10"
        >
          <div class="pl-3.5 pr-2 text-gray-400 flex items-center">
            <!-- Outline Mail Icon -->
            <svg
              fill="none"
              class="w-5 h-5"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.8"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <input
            type="email"
            id="email"
            class="flex-1 border-none bg-transparent py-2.5 text-[0.95rem] text-[#334155] outline-none w-full placeholder-gray-400"
            placeholder="ejemplo@kiora.com"
            required
          />
        </div>
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        id="submitBtn"
        class="w-full bg-[#ec131e] hover:bg-[#d0111a] text-white border-none rounded-lg py-2.5 text-[1rem] font-semibold cursor-pointer transition-colors duration-200 shadow-[0_2px_4px_rgba(237,19,30,0.15)] disabled:opacity-70 disabled:cursor-not-allowed mb-4"
        >Enviar instrucciones</button
      >

      <!-- Back Link -->
      <div class="text-center">
        <a
          href="/login"
          class="text-[0.85rem] text-[#64748b] hover:text-[#ec131e] font-medium transition-colors"
        >
          Volver a iniciar sesión
        </a>
      </div>
    </form>
    <div id="loadingOverlay" class="hidden">
      <Loading message="Enviando..." />
    </div>
  </body><script>
    import { FetchHttpClient } from "../core/http/HttpClient";
    import { SweetAlertService } from "../core/ui/AlertService";

    const API_URL =
      import.meta.env.PUBLIC_API_URL || "http://localhost:3001/api";

    const httpClient = new FetchHttpClient(API_URL);
    const alertService = new SweetAlertService();

    const recoverForm = document.getElementById("recoverForm");
    const emailInput = document.getElementById("email") as HTMLInputElement;
    const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
    const loadingOverlay = document.getElementById("loadingOverlay");

    recoverForm?.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!emailInput || !submitBtn) return;

      const email = emailInput.value;

      // Show loading state
      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando...";
      loadingOverlay?.classList.remove("hidden");

      try {
        const response = await httpClient.post<any>("/auth/recuperar-password", {
          correo_usu: email,
        });

        if (!response.ok) {
          throw new Error(response.error || "Error al procesar la solicitud");
        }

        // Show success message
        await alertService.showSuccess(
          "Correo enviado",
          response.data?.message ||
            "Si el correo está registrado, recibirá un enlace para restablecer tu contraseña.",
        );
        
        window.location.href = "/login";
      } catch (error: any) {
        alertService.showError("Error", error.message);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Enviar instrucciones";
        loadingOverlay?.classList.add("hidden");
      }
    });
  </script>
</html>
