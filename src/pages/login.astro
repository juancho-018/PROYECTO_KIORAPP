---
import LoginForm from "../components/auth/LoginForm";
import GlobalControls from "../components/ui/GlobalControls";
import MainLayout from "@/layouts/mainlayout.astro";
---

<MainLayout title="Iniciar Sesión - Kiora">
  <div
    class="flex flex-col items-center justify-center min-h-screen w-full relative z-10 px-4"
  >
    <!-- Abstract Background Detail -->
    <div
      class="absolute -top-50 -right-25 w-150 h-150 rounded-full bg-[radial-gradient(circle,rgba(237,27,36,0.06)_0%,rgba(250,250,252,0)_70%)] -z-10 pointer-events-none"
    >
    </div>

    <!-- App Logo -->
    <img
      src="/img/logo-kiora-vectorizado.svg"
      alt="Kiora Logo"
      class="w-48 h-auto mt-4 mb-6 relative z-10 object-contain"
    />

    <LoginForm client:load />

    <!-- Legal & Help Links -->
    <div class="fixed bottom-22 left-4 flex flex-col gap-2 text-left z-50">
      <a
        href="/ayuda"
        class="text-xs text-[#ec131e] hover:text-white hover:bg-[#ec131e] font-black transition-colors bg-white/90 backdrop-blur-md px-4 py-2 rounded-r-xl shadow-lg border border-l-0 border-slate-100 hover:border-[#ec131e] inline-flex items-center gap-2 group"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Centro de Ayuda
      </a>
      <a
        href="/terminos"
        class="text-xs text-slate-500 hover:text-[#ec131e] font-medium transition-colors bg-white/90 backdrop-blur-md px-4 py-2 rounded-r-xl shadow-lg border border-l-0 border-slate-100 hover:border-[#ec131e]/30 inline-flex items-center"
      >
        Términos y Condiciones
      </a>
      <a
        href="/privacidad"
        class="text-xs text-slate-500 hover:text-[#ec131e] font-medium transition-colors bg-white/90 backdrop-blur-md px-4 py-2 rounded-r-xl shadow-lg border border-l-0 border-slate-100 hover:border-[#ec131e]/30 inline-flex items-center"
      >
        Política de Privacidad
      </a>
    </div>
  </div>
  <GlobalControls client:load />
</MainLayout>
