---
import ResetPasswordForm from "../components/auth/ResetPasswordForm";
import GlobalControls from "../components/ui/GlobalControls";
import MainLayout from "@/layouts/mainlayout.astro";
---

<MainLayout title="Restablecer Contraseña - Kiora">
    <!-- Abstract Background Detail -->
    <div
      class="absolute -top-50 -right-25 w-150 h-150 rounded-full bg-[radial-gradient(circle,rgba(237,27,36,0.06)_0%,rgba(250,250,252,0)_70%)] -z-10 pointer-events-none"
    >
    </div>

    <!-- App Logo -->
    <img
      src="/img/logo-kiora-vectorizado.svg"
      alt="Kiora Logo"
      class="w-48 h-auto mt-4 mb-6 relative z-10 object-contain"
    />

    <p
      class="text-[0.95rem] text-[#64748b] m-0 mb-8 font-medium text-center max-w-md px-4"
    >
      Estás a un paso de recuperar el acceso. Escribe y confirma tu nueva contraseña.
    </p>

    <ResetPasswordForm client:load />
    <GlobalControls client:load />
</MainLayout>
