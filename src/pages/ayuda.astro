---
import HelpCenter from "@/components/help/HelpCenter";
import GlobalControls from "@/components/ui/GlobalControls";
import MainLayout from "@/layouts/mainlayout.astro";
---

<MainLayout title="Centro de Ayuda - Kiora">
  <div style="background: var(--md-background, #fff8f6); min-height: 100vh;">
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-[-15%] right-[-10%] w-[600px] h-[600px] rounded-full"
        style="background: radial-gradient(circle, rgba(236,19,30,0.04) 0%, transparent 70%);" />
      <div class="absolute bottom-[-15%] left-[-10%] w-[500px] h-[500px] rounded-full"
        style="background: radial-gradient(circle, rgba(61,26,16,0.05) 0%, transparent 70%);" />
    </div>
    <div class="relative z-10 pt-8 px-4 sm:px-6">
      <HelpCenter client:load />
    </div>
  </div>
  <GlobalControls client:load />
</MainLayout>
